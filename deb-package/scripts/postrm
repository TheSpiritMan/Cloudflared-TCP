#!/bin/sh
set -e

# Define files to be cleaned up
FILES="/usr/local/bin/cloudflared-tcp.sh /etc/cloudflared-tcp.conf /etc/systemd/system/cloudflared-tcp.service"

case "$1" in
    purge|remove)
        # Stop and disable service if systemd is running
        if [ -d /run/systemd/system ]; then
            systemctl stop cloudflared-tcp.service >/dev/null 2>&1 || true
            systemctl disable cloudflared-tcp.service >/dev/null 2>&1 || true
            systemctl daemon-reload >/dev/null 2>&1 || true
        fi

        # Remove files (rm -f doesn't fail if file is missing, so no 'if' needed)
        rm -f $FILES
        ;;

    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # No action needed for these states
        ;;

    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

exit 0